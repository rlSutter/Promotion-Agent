# Environment Configuration
# Copy this to .env and fill in your values

# Your Substack RSS feed URL (public feed, not the publish dashboard)
# Use: https://YOURNAME.substack.com/feed
# Wrong: https://YOURNAME.substack.com/publish/home (that's the private dashboard)
SUBSTACK_URL=https://yoursubstack.substack.com/feed

# Substack Developer API (optional)
# Profile stats (follower count, subscribers) come from: https://support.substack.com/hc/en-us/articles/45099095296916
# Add your API key here when Substack provides it (pending). Used for authenticated requests when available.
SUBSTACK_API_KEY=

# LinkedIn handle for Substack profile lookup (optional). Example: johndoe from https://www.linkedin.com/in/johndoe
# When set, the agent fetches your Substack profile stats (followers, free subscribers) from the Substack Developer API.
SUBSTACK_LINKEDIN_HANDLE=

# Anthropic API Key
# Get it from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic model (optional — defaults to claude-sonnet-4-20250514)
# Claude Sonnet is the recommended balance of quality and cost for this workload.
# Switch to a different model ID if you want to experiment.
# See available models: https://docs.anthropic.com/en/docs/about-claude/models
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Check interval in minutes (default: 60)
CHECK_INTERVAL_MINUTES=60

# Optional: Override database path (use when DB is in temp due to OneDrive)
# PROMOTION_AGENT_DB=C:/Users/YourName/AppData/Local/Temp/promotion_agent.db

# Dashboard authentication (recommended when deploying to a public URL)
# Leave both blank for local use — auth is skipped when neither is set.
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD=choose-a-strong-password
